<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 11px; color: #333; margin: 20px; }
        .header-table { width: 100%; border-collapse: collapse; border-bottom: 2px solid #2563eb; margin-bottom: 15px; }
        .header-table td { vertical-align: top; padding-bottom: 10px; }
        .header-table td:last-child { text-align: right; }
        .logo { max-width: 120px; max-height: 60px; margin-bottom: 6px; }
        .atelier-meta { font-size: 10px; color: #555; line-height: 1.5; }
        h1 { color: #2563eb; font-size: 18px; margin: 0; }
        .info-block { margin-bottom: 12px; }
        .info-block h3 { color: #1e40af; font-size: 13px; border-bottom: 1px solid #ddd; padding-bottom: 3px; margin: 8px 0 5px; }
        table { width: 100%; border-collapse: collapse; margin: 5px 0; }
        table.info td { padding: 2px 8px; }
        table.info td:first-child { font-weight: bold; width: 35%; color: #555; }
        table.checks { border: 1px solid #ccc; }
        table.checks th { background: #f3f4f6; padding: 4px 6px; border: 1px solid #ccc; text-align: left; }
        table.checks td { padding: 4px 6px; border: 1px solid #ccc; }
        .status-ok { color: #16a34a; font-weight: bold; }
        .status-nok { color: #dc2626; font-weight: bold; }
        .section { margin-bottom: 12px; }
        .section-content { background: #f9fafb; padding: 6px 10px; border-radius: 4px; border: 1px solid #e5e7eb; }
        .sig-table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        .sig-table td.sig-box { width: 45%; border: 1px solid #ccc; padding: 8px; text-align: center; }
        .sig-table td.sig-spacer { width: 10%; border: none; }
        .sig-box p { margin: 3px 0; font-size: 10px; color: #666; }
        .photos-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
        .photos-table td { width: 33%; padding: 6px; vertical-align: top; }
        .photo-card { border: 1px solid #ddd; background: #fafafa; padding: 6px; }
        .photo-card img { width: 100%; max-height: 120px; object-fit: cover; }
        .photo-caption { font-size: 9px; color: #555; margin-top: 4px; }
        .footer { margin-top: 20px; border-top: 1px solid #ddd; padding-top: 8px; font-size: 9px; color: #999; text-align: center; }
        .badge { padding: 2px 8px; border: 1px solid #ccc; font-size: 10px; font-weight: bold; }
        .badge-signe { background: #dcfce7; color: #166534; }
        .badge-brouillon { background: #fef9c3; color: #854d0e; }
    </style>
</head>
<body>
    <table class="header-table">
        <tr>
            <td>
                {% if logo_data_uri is defined and logo_data_uri %}
                <img src="{{ logo_data_uri }}" alt="Logo atelier" class="logo"><br>
                {% endif %}
                <div class="atelier-meta">
                    {% if atelier is defined and atelier %}
                    <strong>{{ atelier.nom }}</strong><br>
                    {% if atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                    {% if atelier.cp or atelier.ville %}{{ atelier.cp|default('') }} {{ atelier.ville|default('') }}<br>{% endif %}
                    {% if atelier.telephone %}Tél : {{ atelier.telephone }}<br>{% endif %}
                    {% if atelier.email %}{{ atelier.email }}<br>{% endif %}
                    {% if atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    {% endif %}
                </div>
            </td>
            <td style="text-align:right;">
                <h1>Rapport d'intervention</h1>
                <p style="margin:4px 0;font-size:10px;color:#666;">
                    N° RDV : {{ rdv.id }}<br>
                    <span class="badge badge-{{ rapport.statut }}">{{ rapport.statut | upper }}</span><br>
                    Édité le {{ "now" | date("d/m/Y H:i") }}
                </p>
            </td>
        </tr>
    </table>

    {% if client %}
    <div class="info-block">
        <h3>Client</h3>
        <table class="info">
            <tr><td>Nom</td><td>{{ client.nom }} {{ client.prenom | default('') }}</td></tr>
            {% if client.telephone %}<tr><td>Téléphone</td><td>{{ client.telephone }}</td></tr>{% endif %}
            {% if client.email %}<tr><td>Email</td><td>{{ client.email }}</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    {% if vehicule %}
    <div class="info-block">
        <h3>Véhicule</h3>
        <table class="info">
            <tr><td>Marque / Modèle</td><td>{{ vehicule.marque | default('') }} {{ vehicule.modele | default('') }}</td></tr>
            {% if vehicule.plaque %}<tr><td>Immatriculation</td><td>{{ vehicule.plaque }}</td></tr>{% endif %}
            {% if rapport.kilometrageRestitution %}<tr><td>Kilométrage restitution</td><td>{{ rapport.kilometrageRestitution }} km</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    <div class="section">
        <h3>Travaux réalisés</h3>
        <div class="section-content">{{ rapport.travauxRealises | default('Non renseigné') | nl2br }}</div>
    </div>

    {% if rapport.alertes %}
    <div class="section">
        <h3>Alertes</h3>
        <div class="section-content">
            <ul>
            {% for alerte in rapport.alertes %}
                <li>{{ alerte }}</li>
            {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    <div class="section">
        <h3>Recommandations</h3>
        <div class="section-content">{{ rapport.recommandations | default('Aucune') | nl2br }}</div>
    </div>

    {% if rapport.prochaineRevisionKm or rapport.prochaineRevisionDate %}
    <div class="info-block">
        <h3>Prochaine révision</h3>
        <table class="info">
            {% if rapport.prochaineRevisionKm %}<tr><td>Kilométrage</td><td>{{ rapport.prochaineRevisionKm }} km</td></tr>{% endif %}
            {% if rapport.prochaineRevisionDate %}<tr><td>Date</td><td>{{ rapport.prochaineRevisionDate | date("d/m/Y") }}</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    {% if rapport.garantie %}
    <div class="section">
        <h3>Garantie</h3>
        <div class="section-content">{{ rapport.garantie | nl2br }}</div>
    </div>
    {% else %}
    <div class="section">
        <h3>Garantie</h3>
        <div class="section-content">Travaux couverts par garantie {{ garantie_jours|default(30) }} jours à compter de la restitution. Pièces neuves garanties 2 ans minimum (articles L.217-3 et suivants du Code de la consommation, article 1641 du Code civil).</div>
    </div>
    {% endif %}

    {% if essai %}
    <div class="info-block">
        <h3>Essai routier</h3>
        <table class="info">
            {% if essai.kmDebut %}<tr><td>Km début</td><td>{{ essai.kmDebut }}</td></tr>{% endif %}
            {% if essai.kmFin %}<tr><td>Km fin</td><td>{{ essai.kmFin }}</td></tr>{% endif %}
            {% if essai.distance %}<tr><td>Distance</td><td>{{ essai.distance }} km</td></tr>{% endif %}
            {% if essai.dureeMinutes %}<tr><td>Durée</td><td>{{ essai.dureeMinutes }} min</td></tr>{% endif %}
        </table>

        {% if essai.pointsControle %}
        <table class="checks" style="margin-top: 8px;">
            <thead>
                <tr><th>Point de contrôle</th><th>Résultat</th><th>Commentaire</th></tr>
            </thead>
            <tbody>
            {% for pt in essai.pointsControle %}
                <tr>
                    <td>{{ pt.label }}</td>
                    <td>
                        {% if pt.ok is same as(true) %}<span class="status-ok">OK</span>
                        {% elseif pt.ok is same as(false) %}<span class="status-nok">NOK</span>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ pt.commentaire | default('') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}

        {% if essai.anomalies %}
        <p><strong>Anomalies :</strong> {{ essai.anomalies }}</p>
        {% endif %}
        {% if essai.actionsCorrectives %}
        <p><strong>Actions correctives :</strong> {{ essai.actionsCorrectives }}</p>
        {% endif %}
    </div>
    {% endif %}

    {% if report_photos is defined and report_photos|length > 0 %}
    <div class="section">
        <h3>Photos d'intervention / restitution</h3>
        <table class="photos-table">
            <tr>
                {% for photo in report_photos %}
                    <td>
                        <div class="photo-card">
                            <img src="{{ photo.src }}" alt="{{ photo.label|default('Photo atelier') }}">
                            <div class="photo-caption">
                                {{ photo.label|default('Photo atelier') }}{% if photo.takenAt %}<br>{{ photo.takenAt }}{% endif %}
                            </div>
                        </div>
                    </td>
                    {% if loop.index is divisible by(3) and not loop.last %}</tr><tr>{% endif %}
                {% endfor %}
            </tr>
        </table>
    </div>
    {% endif %}

    <div style="margin-top:15px;">
        <h3 style="color:#1e40af;font-size:13px;border-bottom:1px solid #ddd;padding-bottom:3px;">Signatures</h3>
        <table class="sig-table">
            <tr>
                <td class="sig-box">
                    <strong>Mécanicien</strong>
                    {% if rapport.signatureMecanicien %}
                        <p>Signé le {{ rapport.signeMecanicienAt | date("d/m/Y H:i") }}</p>
                        {# [SPRINT-5] I28 — Afficher la signature comme image si data URI #}
                        {% if rapport.signatureMecanicien starts with 'data:' %}
                            <img src="{{ rapport.signatureMecanicien }}" alt="Signature mécanicien" style="max-width:140px;max-height:60px;margin-top:4px;" />
                        {% else %}
                            <p style="font-style:italic;">✓ Signature enregistrée</p>
                        {% endif %}
                    {% else %}
                        <p style="color:#999;">En attente</p>
                    {% endif %}
                </td>
                <td class="sig-spacer"></td>
                <td class="sig-box">
                    <strong>Client</strong>
                    {% if rapport.signatureClient %}
                        <p>Signé le {{ rapport.signeClientAt | date("d/m/Y H:i") }}</p>
                        {# [SPRINT-5] I28 — Afficher la signature client comme image si data URI #}
                        {% if rapport.signatureClient starts with 'data:' %}
                            <img src="{{ rapport.signatureClient }}" alt="Signature client" style="max-width:140px;max-height:60px;margin-top:4px;" />
                        {% else %}
                            <p style="font-style:italic;">✓ Signature enregistrée</p>
                        {% endif %}
                    {% else %}
                        <p style="color:#999;">En attente de signature à la restitution</p>
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    <div class="footer">
        {% if rapport.signedHash %}
            Empreinte de vérification : {{ rapport.signedHash }}<br>
        {% endif %}
        Rapport d'intervention figé à l'édition — {% if atelier is defined and atelier %}{{ atelier.nom }}{% else %}Atelier Moto{% endif %}
    </div>
    {% include 'pdf/_paddock_footer.html.twig' %}
</body>
</html>
