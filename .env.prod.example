# ============================================================
# Paddock — modèle d'environnement de PRODUCTION
# Copier en `.env` sur le serveur cible et remplir chaque valeur.
# Détail et ordre des opérations : DEPLOIEMENT.md
# ============================================================

# --- Domaine public (vitrine + espace client, port 443 auto via Let's Encrypt)
# Exemple : PUBLIC_DOMAIN=atelier-mbz.fr
# Laisser vide en dev (retombe sur le port 81 local).
PUBLIC_DOMAIN=

# URL publique complète, utilisée dans les liens des emails
PUBLIC_URL=https://CHANGEME.fr

# --- Symfony
APP_ENV=prod
# Générer : openssl rand -hex 32
APP_SECRET=CHANGEME
# Clés JWT : régénérer sur le serveur (php bin/console lexik:jwt:generate-keypair --overwrite)
# puis reporter la passphrase choisie ici
JWT_SECRET_KEY=CHANGEME
JWT_PASSPHRASE=CHANGEME

# --- Base de données
POSTGRES_USER=atelier
# Générer : openssl rand -hex 24
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=atelier_moto

# --- Compte admin initial (créé au premier démarrage)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME

# --- Mercure (temps réel back-office)
# Générer : openssl rand -hex 32
MERCURE_JWT_SECRET=CHANGEME

# --- Emails : SMTP réel (remplace MailHog)
# Exemple OVH : smtp://user:pass@ssl0.ovh.net:465
MAILER_DSN=CHANGEME

# --- Durcissement production
# Forcer le flag Secure sur les cookies client si le proxy TLS
# ne transmet pas X-Forwarded-Proto (sinon détection auto)
CLIENT_COOKIE_SECURE=1
# Rate limit booking public : ne PAS poser la variable en prod
# (retombe sur le défaut de 5/min). La ligne reste en commentaire.
# PUBLIC_BOOKING_RATE_LIMIT=5
