<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #222; margin: 22px; }
        .header { border-bottom: 2px solid #d97706; padding-bottom: 10px; margin-bottom: 18px; }
        .header-table { width: 100%; border-collapse: collapse; }
        .logo { max-width: 120px; max-height: 60px; margin-bottom: 8px; }
        h1 { margin: 0; color: #b45309; font-size: 18px; }
        .sub { color: #666; font-size: 10px; }
        .box { border: 1px solid #ddd; border-radius: 6px; padding: 10px 12px; margin-bottom: 12px; }
        .warn { background: #fff7ed; border-color: #fdba74; }
        .ok { background: #f0fdf4; border-color: #86efac; }
        .grid { width: 100%; border-collapse: collapse; margin-top: 8px; }
        .grid td { padding: 6px 8px; border-bottom: 1px solid #eee; vertical-align: top; }
        .grid td:first-child { width: 35%; color: #666; font-weight: bold; }
        .section-title { font-size: 13px; font-weight: 700; margin: 0 0 6px; color: #111; }
        .muted { color: #6b7280; }
        .footer { margin-top: 24px; font-size: 9px; color: #777; border-top: 1px solid #ddd; padding-top: 8px; }
        ul { margin: 6px 0 0 16px; padding: 0; }
    </style>
</head>
<body>
    <div class="header">
        <table class="header-table">
            <tr>
                <td>
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo" class="logo">
                    {% endif %}
                    <div>
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        {% if atelier and atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                        {% if atelier and (atelier.cp or atelier.ville) %}{{ atelier.cp }} {{ atelier.ville }}<br>{% endif %}
                        {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    </div>
                </td>
                <td style="text-align:right">
                    <h1>Préparation déclaration d'achat SIV</h1>
                    <div class="sub">Document de préparation interne prérempli — dossier VO n° {{ purchase.id }}</div>
                    <div class="sub">Édité le {{ 'now'|date('d/m/Y H:i') }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="box {{ blockers is empty ? 'ok' : 'warn' }}">
        <div class="section-title">État du dossier</div>
        {% if blockers is empty %}
            <div>Le dossier contient les informations essentielles pour préparer la saisie SIV.</div>
        {% else %}
            <div>Des points restent à régulariser avant finalisation légale :</div>
            <ul>
                {% for blocker in blockers %}
                    <li>{{ blocker }}</li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    <div class="box">
        <div class="section-title">Vendeur</div>
        <table class="grid">
            <tr><td>Nom / prénom</td><td>{{ purchase.seller.prenom ?? '' }} {{ purchase.seller.nom ?? '' }}</td></tr>
            <tr><td>Adresse</td><td>{{ purchase.seller.adresse ?? 'À compléter' }}</td></tr>
            <tr><td>Téléphone</td><td>{{ purchase.seller.telephone ?? 'À compléter' }}</td></tr>
            <tr><td>Email</td><td>{{ purchase.seller.email ?? 'À compléter' }}</td></tr>
            <tr><td>Pièce d'identité</td><td>{{ purchase.sellerIdType ?? 'À compléter' }} {{ purchase.sellerIdNumber ? '— n° ' ~ purchase.sellerIdNumber : '' }} {% if purchase.sellerIdDate %}(délivrée le {{ purchase.sellerIdDate|date('d/m/Y') }}){% endif %}</td></tr>
        </table>
    </div>

    <div class="box">
        <div class="section-title">Véhicule</div>
        <table class="grid">
            <tr><td>Immatriculation</td><td>{{ purchase.vehicule.plaque ?? 'À compléter' }}</td></tr>
            <tr><td>VIN</td><td>{{ purchase.vehicule.vin ?? 'À compléter' }}</td></tr>
            <tr><td>Marque / modèle</td><td>{{ purchase.vehicule.marque ?? '—' }} {{ purchase.vehicule.modele ?? '' }}</td></tr>
            <tr><td>Première MEC</td><td>{% if purchase.vehicule.datePremiereMiseEnCirculation %}{{ purchase.vehicule.datePremiereMiseEnCirculation|date('d/m/Y') }}{% else %}À compléter{% endif %}</td></tr>
            <tr><td>Kilométrage</td><td>{{ purchase.vehicule.mileage ?? 'À compléter' }} km</td></tr>
            <tr><td>Cylindrée</td><td>{{ purchase.vehicule.cylindree ?? 'À compléter' }}</td></tr>
        </table>
    </div>

    <div class="box">
        <div class="section-title">Transaction et contrôle</div>
        <table class="grid">
            <tr><td>Date d'achat</td><td>{% if purchase.purchaseDate %}{{ purchase.purchaseDate|date('d/m/Y') }}{% else %}À compléter{% endif %}</td></tr>
            <tr><td>Prix d'achat</td><td>{{ purchase.purchasePrice|number_format(2, ',', ' ') }} €</td></tr>
            <tr><td>Non-gage</td><td>{% if purchase.nonGageDate %}Vérifié le {{ purchase.nonGageDate|date('d/m/Y') }}{% else %}À compléter{% endif %}</td></tr>
            <tr><td>Contrôle technique</td><td>{{ purchase.controleTechniqueOk ? 'Validé dans le dossier' : 'À vérifier selon le véhicule' }}</td></tr>
            <tr><td>Référence DA</td><td>{{ purchase.sivReference ?? 'À renseigner après saisie SIV' }}</td></tr>
        </table>
    </div>

    <div class="footer">
        Ce document est un support interne de préparation AtelierMBZ. Il aide à éviter la ressaisie, mais ne remplace pas la saisie officielle dans le portail SIV Pro ou chez un prestataire habilité.
    </div>
</body>
</html>
