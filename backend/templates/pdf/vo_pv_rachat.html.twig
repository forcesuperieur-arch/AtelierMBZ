<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #333; margin: 20px; }
        .header { border-bottom: 2px solid #2563eb; padding-bottom: 10px; margin-bottom: 20px; }
        .header-table { width: 100%; border-collapse: collapse; }
        .header-left, .header-right { vertical-align: top; }
        .header-right { text-align: right; }
        .header h1 { color: #2563eb; margin: 0; font-size: 16px; }
        .logo { max-width: 120px; max-height: 60px; margin-bottom: 8px; }
        .atelier-meta { font-size: 10px; color: #555; line-height: 1.4; }
        .info-grid { display: table; width: 100%; margin-bottom: 15px; }
        .info-col { display: table-cell; width: 50%; vertical-align: top; }
        .label { font-weight: bold; color: #666; font-size: 10px; }
        .vehicle-box { background: #f3f4f6; padding: 10px; border-left: 3px solid #2563eb; margin-bottom: 15px; }
        .amount-box { background: #eff6ff; border: 1px solid #2563eb; padding: 12px; margin: 15px 0; text-align: center; }
        .amount-box .price { font-size: 20px; font-weight: bold; color: #2563eb; }
        .clause { margin-bottom: 8px; font-size: 10px; line-height: 1.5; }
        .signatures { margin-top: 40px; display: table; width: 100%; }
        .sig-col { display: table-cell; width: 50%; text-align: center; }
        .sig-line { border-top: 1px solid #333; width: 200px; margin: 40px auto 5px; }
        .sig-image { display: block; max-width: 180px; max-height: 80px; margin: 10px auto 5px; }
        .footer { margin-top: 30px; font-size: 8px; color: #999; text-align: center; border-top: 1px solid #ddd; padding-top: 8px; }
    </style>
</head>
<body>
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="header-left">
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo" class="logo">
                    {% endif %}
                    <div class="atelier-meta">
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        {% if atelier and atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                        {% if atelier and (atelier.cp or atelier.ville) %}{{ atelier.cp }} {{ atelier.ville }}<br>{% endif %}
                        {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    </div>
                </td>
                <td class="header-right">
                    <h1>PROCÈS-VERBAL DE RACHAT</h1>
                    <p>N° PVR-{{ purchase.id }} — {{ purchase.purchaseDate ? purchase.purchaseDate|date('d/m/Y') : "now"|date('d/m/Y') }}</p>
                </td>
            </tr>
        </table>
    </div>

    <div class="info-grid">
        <div class="info-col">
            <p class="label">Vendeur</p>
            <p>
                {{ purchase.seller.prenom ?? '' }} {{ purchase.seller.nom }}<br>
                {% if purchase.seller.adresse %}{{ purchase.seller.adresse }}<br>{% endif %}
                {% if purchase.seller.telephone %}Tél : {{ purchase.seller.telephone }}<br>{% endif %}
                {% if purchase.seller.email %}{{ purchase.seller.email }}{% endif %}
            </p>
            <p class="label">Pièce d'identité</p>
            <p>{{ purchase.sellerIdType ?? '—' }} n° {{ purchase.sellerIdNumber ?? '—' }}
                {% if purchase.sellerIdDate %} du {{ purchase.sellerIdDate|date('d/m/Y') }}{% endif %}
            </p>
        </div>
        <div class="info-col">
            <p class="label">Acquéreur</p>
            <p>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}<br>
               {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
            </p>
            {% if purchase.expert %}
            <p class="label">Expert</p>
            <p>{{ purchase.expert.prenom ?? '' }} {{ purchase.expert.nom ?? '' }}</p>
            {% endif %}
        </div>
    </div>

    <div class="vehicle-box">
        <p class="label">Véhicule objet de la transaction</p>
        <p>
            {{ purchase.vehicule.marque }} {{ purchase.vehicule.modele }}<br>
            Immatriculation : {{ purchase.vehicule.plaque }}<br>
            {% if purchase.vehicule.cylindree %}Cylindrée : {{ purchase.vehicule.cylindree }} cc<br>{% endif %}
            {% if purchase.vehicule.vin %}VIN : {{ purchase.vehicule.vin }}<br>{% endif %}
            {% if purchase.vehicule.annee %}Année : {{ purchase.vehicule.annee }}<br>{% endif %}
            {% if purchase.vehicule.mileage %}Kilométrage au compteur : {{ purchase.vehicule.mileage }} km<br>{% endif %}
            {% if purchase.vehicule.couleur %}Couleur : {{ purchase.vehicule.couleur }}{% endif %}
        </p>
    </div>

    <div class="amount-box">
        <p>Prix de rachat convenu</p>
        <p class="price">{{ purchase.purchasePrice|number_format(2, ',', ' ') }} €</p>
    </div>

    <div class="clause">
        {% if purchase.nonGageDate %}
        <p>✓ Certificat de non-gage vérifié le {{ purchase.nonGageDate|date('d/m/Y') }}</p>
        {% endif %}
        {% if purchase.controleTechniqueOk %}
        <p>✓ Contrôle technique en cours de validité</p>
        {% endif %}
    </div>

    <div class="clause">
        <p>Le vendeur déclare :</p>
        <p>— Être le propriétaire légitime du véhicule décrit ci-dessus</p>
        <p>— Que le véhicule ne fait l'objet d'aucun gage, opposition ou saisie</p>
        <p>— Que le kilométrage indiqué est exact à sa connaissance</p>
    </div>

    {% if purchase.notes %}
    <div class="clause">
        <p><strong>Observations :</strong> {{ purchase.notes }}</p>
    </div>
    {% endif %}

    <div class="signatures">
        <div class="sig-col">
            {% if companion_signature %}
            <img src="{{ companion_signature }}" alt="Signature vendeur" class="sig-image">
            {% endif %}
            <div class="sig-line"></div>
            <p>Le Vendeur<br>Lu et approuvé</p>
        </div>
        <div class="sig-col">
            <div class="sig-line"></div>
            <p>L'Acquéreur<br>{{ atelier and atelier.nom ? atelier.nom : '' }}</p>
        </div>
    </div>

    <div class="footer">
        Document établi en deux exemplaires originaux.
    </div>
</body>
</html>
