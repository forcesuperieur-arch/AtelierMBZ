<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 7.5px; color: #333; margin: 8px; }
        .header { border-bottom: 2px solid #2563eb; padding-bottom: 6px; margin-bottom: 10px; }
        .header h1 { color: #2563eb; margin: 0; font-size: 13px; }
        .logo { max-width: 80px; max-height: 35px; margin-bottom: 3px; }
        .atelier-meta { font-size: 8px; color: #555; }
        table.register { width: 100%; border-collapse: collapse; margin-top: 6px; font-size: 7px; table-layout: fixed; }
        table.register th { background: #1e3a5f; color: white; padding: 2px 3px; text-align: left; word-break: break-word; }
        table.register td { padding: 2px 3px; border-bottom: 1px solid #ddd; vertical-align: top; word-break: break-word; overflow: hidden; }
        table.register tr:nth-child(even) { background: #f9fafb; }
        .mention { margin-top: 12px; font-size: 7px; color: #888; }
        .footer { margin-top: 15px; font-size: 7px; color: #999; text-align: center; border-top: 1px solid #ddd; padding-top: 5px; }
        .mode-paiement { font-size: 7px; color: #555; white-space: normal; }
        /* Largeurs colonnes adaptées A4 paysage */
        col.c-num   { width: 3.5%; }
        col.c-type  { width: 4.5%; }
        col.c-datea { width: 6%; }
        col.c-desc  { width: 11%; }
        col.c-immat { width: 7%; }
        col.c-vend  { width: 9%; }
        col.c-piece { width: 8%; }
        col.c-pacha { width: 6%; }
        col.c-mpacha{ width: 7%; }
        col.c-datev { width: 6%; }
        col.c-ache  { width: 9%; }
        col.c-pvente{ width: 6%; }
        col.c-mpvente{ width: 7%; }
    </style>
</head>
<body>
    <div class="header">
        {% if logo_data_uri %}
        <img src="{{ logo_data_uri }}" alt="Logo" class="logo">
        {% endif %}
        <h1>LIVRE DE POLICE — Extrait</h1>
        <div class="atelier-meta">
            {{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}
            {% if atelier and atelier.siret %} — SIRET : {{ atelier.siret }}{% endif %}
            <br>Édité le {{ "now"|date('d/m/Y à H:i') }}
        </div>
    </div>

    <table class="register">
        <colgroup>
            <col class="c-num"><col class="c-type"><col class="c-datea"><col class="c-desc">
            <col class="c-immat"><col class="c-vend"><col class="c-piece">
            <col class="c-pacha"><col class="c-mpacha">
            <col class="c-datev"><col class="c-ache"><col class="c-pvente"><col class="c-mpvente">
        </colgroup>
        <thead>
            <tr>
                <th>N°</th>
                <th>Type</th>
                <th>Date acq.</th>
                <th>Description</th>
                <th>Immat.</th>
                <th>Vendeur</th>
                <th>Pièce id.</th>
                <th>Prix achat</th>
                <th>Mode paiement achat</th>
                <th>Date vente</th>
                <th>Acheteur</th>
                <th>Prix vente</th>
                <th>Mode paiement vente</th>
            </tr>
        </thead>
        <tbody>
            {% for e in entries %}
            <tr>
                <td>{{ e.numeroOrdre }}</td>
                <td>{{ e.type }}</td>
                <td>{{ e.dateAcquisition|date('d/m/Y') }}</td>
                <td>{{ e.descriptionBien }}</td>
                <td>{{ e.immatriculation }}</td>
                <td>{{ e.vendeurPrenom }} {{ e.vendeurNom }}</td>
                <td>{{ e.vendeurIdType }} {{ e.vendeurIdNumber }}</td>
                <td style="text-align: right;">{{ e.prixAchat|number_format(2, ',', ' ') }} €</td>
                <td class="mode-paiement">
                    {{ e.modePaiement|upper }}
                    {% if e.numeroCheque %}<br>Chèque n° {{ e.numeroCheque }}{% endif %}
                    {% if e.nomBanque %}<br>{{ e.nomBanque }}{% endif %}
                </td>
                <td>{{ e.dateVente ? e.dateVente|date('d/m/Y') : '—' }}</td>
                <td>{{ e.acheteurPrenom ?? '' }} {{ e.acheteurNom ?? '' }}</td>
                <td style="text-align: right;">{{ e.prixVente ? e.prixVente|number_format(2, ',', ' ') ~ ' €' : '—' }}</td>
                <td class="mode-paiement">
                    {% if e.modePaiementVente %}
                        {{ e.modePaiementVente|upper }}
                        {% if e.numeroChequeVente %}<br>Chèque n° {{ e.numeroChequeVente }}{% endif %}
                        {% if e.nomBanqueVente %}<br>{{ e.nomBanqueVente }}{% endif %}
                    {% else %}—{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="mention">
        Registre tenu conformément aux articles 321-7 et 321-8 du Code Pénal et au décret n° 2009-1104.
        Ce registre doit être conservé pendant 5 ans. Toute modification est interdite.
    </div>

    <div class="footer">
        {{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}
        — Extrait généré depuis le registre immuable
    </div>
    {% include 'pdf/_paddock_footer.html.twig' %}
</body>
</html>
