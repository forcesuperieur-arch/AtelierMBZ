<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #333; margin: 20px; }
        .header { border-bottom: 2px solid #2563eb; padding-bottom: 10px; margin-bottom: 20px; }
        .header-table { width: 100%; border-collapse: collapse; }
        .header-left, .header-right { vertical-align: top; }
        .header-right { text-align: right; }
        .header h1 { color: #2563eb; margin: 0; font-size: 18px; }
        .logo { max-width: 120px; max-height: 60px; margin-bottom: 8px; }
        .atelier-meta { font-size: 10px; color: #555; line-height: 1.4; }
        .info-grid { display: table; width: 100%; margin-bottom: 20px; }
        .info-col { display: table-cell; width: 50%; vertical-align: top; }
        .info-col-3 { display: table-cell; width: 33%; vertical-align: top; }
        .label { font-weight: bold; color: #666; }
        .section { margin-bottom: 24px; page-break-inside: avoid; }
        .section-title { font-size: 13px; font-weight: bold; color: #2563eb; border-bottom: 1px solid #2563eb; padding-bottom: 4px; margin-bottom: 10px; }
        .alert-box { background: #fef2f2; border-left: 4px solid #ef4444; padding: 8px 12px; margin: 8px 0; }
        .recommandation-box { background: #fffbeb; border-left: 4px solid #f59e0b; padding: 8px 12px; margin: 8px 0; }
        .garantie-box { background: #f0fdf4; border-left: 4px solid #10b981; padding: 8px 12px; margin: 8px 0; }
        .notes-box { background: #eff6ff; border-left: 4px solid #3b82f6; padding: 8px 12px; margin: 8px 0; }
        .checkup-box { background: #f8fafc; border: 1px solid #e2e8f0; padding: 8px 12px; margin: 8px 0; }
        .checkup-item { padding: 3px 0; border-bottom: 1px dashed #e2e8f0; }
        .checkup-item:last-child { border-bottom: none; }
        .recap-box { background: #f8fafc; border: 1px solid #cbd5e1; padding: 10px 14px; margin: 8px 0; }
        table.lines { width: 100%; border-collapse: collapse; margin-top: 10px; }
        table.lines th { background: #2563eb; color: white; padding: 6px 8px; text-align: left; }
        table.lines td { padding: 5px 8px; border-bottom: 1px solid #ddd; }
        .totals { float: right; width: 250px; margin-top: 20px; }
        .totals table { width: 100%; }
        .totals td { padding: 3px 5px; }
        .totals .total-ttc { font-weight: bold; font-size: 14px; border-top: 2px solid #333; }
        .photos-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .photos-table td { width: 33%; padding: 6px; vertical-align: top; }
        .photo-card { border: 1px solid #ddd; background: #fafafa; padding: 6px; }
        .photo-card img { width: 100%; max-height: 120px; object-fit: cover; }
        .photo-caption { font-size: 9px; color: #555; margin-top: 4px; }
        .signature-grid { display: table; width: 100%; margin-top: 20px; }
        .signature-col { display: table-cell; width: 50%; vertical-align: top; padding-right: 12px; }
        .signature-box { border: 1px solid #ccc; padding: 10px; min-height: 80px; background: #fafafa; }
        .signature-box img { max-width: 180px; max-height: 60px; }
        .signature-label { font-size: 10px; color: #666; margin-bottom: 6px; }
        .page-break { page-break-before: always; }
        .meta-row { font-size: 10px; color: #666; margin-top: 4px; }
        .status-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; background: #e0e7ff; color: #3730a3; }
    </style>
</head>
<body>
    <!-- ===== PAGE 1 : RÉCEPTION ===== -->
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="header-left">
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo atelier" class="logo">
                    {% endif %}
                    <div class="atelier-meta">
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        {% if atelier and atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                        {% if atelier and (atelier.cp or atelier.ville) %}{{ atelier.cp }} {{ atelier.ville }}<br>{% endif %}
                        {% if atelier and atelier.telephone %}Tél : {{ atelier.telephone }}<br>{% endif %}
                        {% if atelier and atelier.email %}{{ atelier.email }}<br>{% endif %}
                        {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    </div>
                </td>
                <td class="header-right">
                    <h1>ORDRE DE RÉPARATION</h1>
                    <p><strong>N° {{ or.numeroOr }}</strong> — {{ or.createdAt|date('d/m/Y H:i') }}</p>
                    <p class="meta-row">Statut : <span class="status-badge">{{ or.statut|upper }}</span></p>
                    {% if or.typeOr != 'initial' %}
                    <p class="meta-row">Type : {{ or.typeOr|capitalize }}</p>
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    <div class="info-grid">
        <div class="info-col">
            <p class="label">Client</p>
            <p>{{ or.snapClientPrenom ?? rdv.client.prenom }} {{ or.snapClientNom ?? rdv.client.nom }}<br>
               {{ rdv.client.telephone }}<br>
               {% if rdv.client.email %}{{ rdv.client.email }}{% endif %}</p>
        </div>
        <div class="info-col">
            <p class="label">Véhicule</p>
            {% set vMarque = or.snapVehiculeMarque ?? (rdv.vehicule ? rdv.vehicule.marque : '') %}
            {% set vModele = or.snapVehiculeModele ?? (rdv.vehicule ? rdv.vehicule.modele : '') %}
            {% set vPlaque = or.snapVehiculePlaque ?? (rdv.vehicule ? rdv.vehicule.plaque : '') %}
            {% if vMarque or vModele %}
            <p>{{ vMarque }} {{ vModele }}<br>
               Plaque: {{ vPlaque }}<br>
               {% if or.kilometrage %}Km réception: {{ or.kilometrage }}{% endif %}</p>
            {% endif %}
        </div>
    </div>

    <div class="info-grid">
        <div class="info-col-3">
            <p class="label">Date & heure du RDV</p>
            <p>{{ rdv.dateRdv|date('d/m/Y') }} à {{ rdv.heureRdv|date('H:i') }}</p>
        </div>
        <div class="info-col-3">
            <p class="label">Pont</p>
            <p>{{ rdv.pont ? rdv.pont.nom : 'Non assigné' }}</p>
        </div>
        <div class="info-col-3">
            <p class="label">Mécanicien</p>
            <p>{{ rdv.mecanicien ? rdv.mecanicien.prenom ~ ' ' ~ rdv.mecanicien.nom : 'Non assigné' }}</p>
        </div>
    </div>

    <div class="section">
        <p class="label">Type d'intervention</p>
        <p>{{ rdv.typeIntervention }}</p>
    </div>

    {% if rdv.commentaire %}
    <div class="section">
        <p class="label">Commentaire réception</p>
        <p>{{ rdv.commentaire|nl2br }}</p>
    </div>
    {% endif %}

    {% if or.travaux %}
    <div class="section">
        <p class="label">Travaux à effectuer</p>
        <p>{{ or.travaux|nl2br }}</p>
    </div>
    {% endif %}

    {% if or.etatVehicule %}
    <div class="section">
        <p class="label">État du véhicule à la réception</p>
        <p>{{ or.etatVehicule|nl2br }}</p>
    </div>
    {% endif %}

    {% if rdv.prixEstime or rdv.tempsEstime %}
    <div class="section">
        <div class="recap-box">
            <table style="width:100%;border-collapse:collapse;">
                <tr>
                    {% if rdv.prixEstime %}
                    <td style="width:50%;border-right:1px solid #cbd5e1;padding-right:12px;">
                        <span class="label">Prix estimé</span><br>
                        <span style="font-size:16px;font-weight:bold;color:#2563eb;">{{ rdv.prixEstime }} €</span>
                    </td>
                    {% endif %}
                    {% if rdv.tempsEstime %}
                    <td style="width:50%;padding-left:12px;">
                        <span class="label">Durée estimée</span><br>
                        <span style="font-size:16px;font-weight:bold;color:#2563eb;">{{ (rdv.tempsEstime // 60) }}h{{ (rdv.tempsEstime % 60)|number_format(0, '', '') }}</span>
                    </td>
                    {% endif %}
                </tr>
            </table>
        </div>
    </div>
    {% endif %}

    {% if reception_photos is defined and reception_photos|length > 0 %}
    <div class="section">
        <div class="section-title">📸 Photos de réception</div>
        <table class="photos-table">
            <tr>
                {% for photo in reception_photos %}
                    <td>
                        <div class="photo-card">
                            <img src="{{ photo.src }}" alt="{{ photo.label|default('Photo réception') }}">
                            <div class="photo-caption">
                                {{ photo.label|default('Photo réception') }}{% if photo.takenAt %}<br>{{ photo.takenAt }}{% endif %}
                            </div>
                        </div>
                    </td>
                    {% if loop.index is divisible by(3) and not loop.last %}</tr><tr>{% endif %}
                {% endfor %}
            </tr>
        </table>
    </div>
    {% endif %}

    <div class="section">
        <div class="signature-grid">
            <div class="signature-col">
                <p class="signature-label"><strong>Signature client réception</strong></p>
                <div class="signature-box">
                    {% if or.signatureClient %}
                    <img src="{{ or.signatureClient }}">
                    {% else %}
                    <p style="color:#999;font-size:10px;">Non signé</p>
                    {% endif %}
                </div>
                {% if or.signedAt %}
                <p class="meta-row">Signé le {{ or.signedAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
            <div class="signature-col">
                <p class="signature-label"><strong>Signature atelier réception</strong></p>
                <div class="signature-box">
                    {% if or.signatureAtelierReception %}
                    <img src="{{ or.signatureAtelierReception }}">
                    {% else %}
                    <p style="color:#999;font-size:10px;">Non signé</p>
                    {% endif %}
                </div>
                {% if or.signeReceptionnisteAt %}
                <p class="meta-row">Signé le {{ or.signeReceptionnisteAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
        </div>
        <p style="font-size: 9px; margin-top: 8px;">Le client reconnaît avoir pris connaissance des travaux à effectuer et donne son accord.</p>
    </div>

    <!-- ===== PAGE 2 : INTERVENTION ===== -->
    <div class="page-break"></div>
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="header-left">
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo atelier" class="logo">
                    {% endif %}
                    <div class="atelier-meta">
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        <span style="font-size:9px;">Document unique OR — N° {{ or.numeroOr }}</span>
                    </div>
                </td>
                <td class="header-right">
                    <h1>FEUILLE D'INTERVENTION</h1>
                    <p><strong>N° {{ or.numeroOr }}</strong></p>
                    {% if rdv.mecanicien %}
                    <p class="meta-row">Mécanicien : {{ rdv.mecanicien.prenom }} {{ rdv.mecanicien.nom }}</p>
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    {% if or.mechanicNotes %}
    <div class="section">
        <div class="section-title">📝 Notes mécanicien</div>
        <div class="notes-box">
            <p>{{ or.mechanicNotes|nl2br }}</p>
        </div>
        {% if or.mechanicNotesUpdatedAt %}
        <p class="meta-row">Mise à jour le {{ or.mechanicNotesUpdatedAt|date('d/m/Y H:i') }}</p>
        {% endif %}
    </div>
    {% endif %}

    {% if or.mechanicCheckup|length > 0 %}
    <div class="section">
        <div class="section-title">🔎 Checkup réception</div>
        <div class="checkup-box">
            {% for key, item in or.mechanicCheckup %}
                <div class="checkup-item">
                    {% if item is iterable %}
                        <strong>{{ item.label is defined ? item.label : key }}</strong>
                        {% if item.value is defined %} : {{ item.value }}{% endif %}
                        {% if item.note is defined %} <em style="color:#666;">({{ item.note }})</em>{% endif %}
                    {% else %}
                        <strong>{{ key }}</strong> : {{ item }}
                    {% endif %}
                </div>
            {% endfor %}
        </div>
        {% if or.mechanicCheckupUpdatedAt %}
        <p class="meta-row">Mise à jour le {{ or.mechanicCheckupUpdatedAt|date('d/m/Y H:i') }}</p>
        {% endif %}
    </div>
    {% endif %}

    {% if or.travauxRealises %}
    <div class="section">
        <div class="section-title">🔧 Travaux réalisés</div>
        <p>{{ or.travauxRealises|nl2br }}</p>
    </div>
    {% endif %}

    {% if or.alertes %}
    <div class="section">
        <div class="section-title">⚠️ Alertes</div>
        <div class="alert-box">
            {% if or.alertes is iterable %}
            <ul style="margin:0;padding-left:16px;">
                {% for alerte in or.alertes %}
                <li>{{ alerte }}</li>
                {% endfor %}
            </ul>
            {% else %}
            <p>{{ or.alertes|nl2br }}</p>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if or.recommandations %}
    <div class="section">
        <div class="section-title">💡 Recommandations</div>
        <div class="recommandation-box">
            <p>{{ or.recommandations|nl2br }}</p>
        </div>
    </div>
    {% endif %}

    {% if or.garantie %}
    <div class="section">
        <div class="section-title">🛡️ Garantie</div>
        <div class="garantie-box">
            <p>{{ or.garantie|nl2br }}</p>
        </div>
    </div>
    {% endif %}

    <div class="info-grid">
        <div class="info-col">
            {% if or.kilometrageRestitution %}
            <p class="label">Kilométrage restitution</p>
            <p>{{ or.kilometrageRestitution }} km</p>
            {% endif %}
        </div>
        <div class="info-col">
            <!-- Prochaine révision retirée — trop variable selon marque/modèle en moto -->
        </div>
    </div>

    {% if intervention_photos is defined and intervention_photos|length > 0 %}
    <div class="section">
        <div class="section-title">📸 Photos intervention</div>
        <table class="photos-table">
            <tr>
                {% for photo in intervention_photos %}
                    <td>
                        <div class="photo-card">
                            <img src="{{ photo.src }}" alt="{{ photo.label|default('Photo') }}">
                            <div class="photo-caption">
                                {{ photo.label|default('Photo') }}{% if photo.takenAt %}<br>{{ photo.takenAt }}{% endif %}
                            </div>
                        </div>
                    </td>
                    {% if loop.index is divisible by(3) and not loop.last %}</tr><tr>{% endif %}
                {% endfor %}
            </tr>
        </table>
    </div>
    {% endif %}

    <div class="section">
        <div class="signature-grid">
            <div class="signature-col">
                <p class="signature-label"><strong>Signature mécanicien</strong></p>
                <div class="signature-box">
                    {% if or.signatureMecanicien %}
                    <img src="{{ or.signatureMecanicien }}">
                    {% else %}
                    <p style="color:#999;font-size:10px;">Non signé</p>
                    {% endif %}
                </div>
                {% if or.signeMecanicienAt %}
                <p class="meta-row">Signé le {{ or.signeMecanicienAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- ===== PAGE 3 : RESTITUTION ===== -->
    <div class="page-break"></div>
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="header-left">
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo atelier" class="logo">
                    {% endif %}
                    <div class="atelier-meta">
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        <span style="font-size:9px;">Document unique OR — N° {{ or.numeroOr }}</span>
                    </div>
                </td>
                <td class="header-right">
                    <h1>RESTITUTION</h1>
                    <p><strong>N° {{ or.numeroOr }}</strong></p>
                </td>
            </tr>
        </table>
    </div>

    <div class="info-grid">
        <div class="info-col">
            <p class="label">Client</p>
            <p>{{ or.snapClientPrenom ?? rdv.client.prenom }} {{ or.snapClientNom ?? rdv.client.nom }}</p>
        </div>
        <div class="info-col">
            <p class="label">Véhicule</p>
            <p>{{ vMarque }} {{ vModele }} — {{ vPlaque }}</p>
        </div>
    </div>

    <div class="section">
        <p>Je soussigné(e) <strong>{{ or.snapClientPrenom ?? rdv.client.prenom }} {{ or.snapClientNom ?? rdv.client.nom }}</strong>, déclare avoir récupéré mon véhicule et pris connaissance des travaux effectués.</p>
        {% if or.kilometrageRestitution %}
        <p class="meta-row">Kilométrage constaté : {{ or.kilometrageRestitution }} km</p>
        {% endif %}
    </div>

    <div class="section">
        <div class="section-title">🔧 Entretien des fluides recommandé</div>
        <div class="checkup-box">
            <div class="checkup-item">Huile moteur — <strong>tous les ans</strong></div>
            <div class="checkup-item">Liquide de frein — <strong>tous les 2 ans</strong></div>
            <div class="checkup-item">Liquide de refroidissement — <strong>tous les 3 ans</strong></div>
        </div>
    </div>

    <div class="section">
        <div class="signature-grid">
            <div class="signature-col">
                <p class="signature-label"><strong>Signature client restitution</strong></p>
                <div class="signature-box">
                    {% if or.signatureClientRestitution %}
                    <img src="{{ or.signatureClientRestitution }}">
                    {% else %}
                    <p style="color:#999;font-size:10px;">Non signé</p>
                    {% endif %}
                </div>
                {% if or.signeClientRestitutionAt %}
                <p class="meta-row">Signé le {{ or.signeClientRestitutionAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
        </div>
    </div>

    {% if restitution_photos is defined and restitution_photos|length > 0 %}
    <div class="section">
        <div class="section-title">📸 Photos restitution</div>
        <table class="photos-table">
            <tr>
                {% for photo in restitution_photos %}
                    <td>
                        <div class="photo-card">
                            <img src="{{ photo.src }}" alt="{{ photo.label|default('Photo restitution') }}">
                            <div class="photo-caption">
                                {{ photo.label|default('Photo restitution') }}{% if photo.takenAt %}<br>{{ photo.takenAt }}{% endif %}
                            </div>
                        </div>
                    </td>
                    {% if loop.index is divisible by(3) and not loop.last %}</tr><tr>{% endif %}
                {% endfor %}
            </tr>
        </table>
    </div>
    {% endif %}

    {% if or.signedHash %}
    <div class="section" style="margin-top: 40px;">
        <p style="font-size: 8px; color: #999; word-break: break-all;">
            Empreinte d'intégrité : {{ or.signedHash }}
        </p>
    </div>
    {% endif %}
</body>
</html>
