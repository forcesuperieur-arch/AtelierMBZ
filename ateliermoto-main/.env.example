POSTGRES_DB=atelier_moto
POSTGRES_USER=atelier
POSTGRES_PASSWORD=ChangeMe_2026!
DATABASE_URL=postgresql://atelier:ChangeMe_2026!@db:5432/atelier_moto

BASE_URL=http://PREPROD_HOST
CORS_ORIGINS=http://PREPROD_HOST
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Superadmin automatique — créé au premier démarrage si non existant
# Rôle: super_admin (accès global à tous les ateliers)
# Laisser vide pour les redémarrages (le superadmin ne sera pas régénéré)
# Remplir avec les identifiants souhaités pour créer le compte superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=SuperAdmin123
SUPERADMIN_EMAIL=superadmin@atelier-moto.local

SECRET_KEY=
SECRET_KEY_FILE=/app/run/secrets/secret_key

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atelier-moto.local
SMTP_TLS=false
SMTP_SSL=false

STATIC_DIR=/app/static
LOG_LEVEL=INFO