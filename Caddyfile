http://{$APP_DOMAIN:localhost}, https://{$APP_DOMAIN:localhost} {
	encode zstd gzip

	handle /.well-known/mercure {
		reverse_proxy mercure:3000
	}

	handle /api/* {
		reverse_proxy php:8000
	}

	handle /uploads/* {
		reverse_proxy php:8000
	}

	handle {
		reverse_proxy nuxt:3000
	}
}

# Public-facing edge (client-only).
# Exposes only customer-facing pages: booking, suivi, demande, mentions, politique.
# Blocks back-office (admin, planning, vo, etc.) and internal companion pages
# (companion / vo-companion are used on-premise from the workshop tablet).
# Dev : port 81 local (défaut posé dans docker-compose). Prod : poser
# PUBLIC_DOMAIN dans .env → Caddy sert le domaine en HTTPS (Let's Encrypt
# automatique, ports 80/443 requis).
{$PUBLIC_DOMAIN} {
	encode zstd gzip

	# Public API — whitelist stricte : booking/suivi/demande/restitution publics,
	# portail client, clauses légales. Tout le reste (companion, photos staff,
	# debug, APIs internes) reste inaccessible depuis Internet.
	@public_api {
		path /api/public/* /api/client /api/client/* /api/clauses-legales /api/clauses-legales/*
	}
	handle @public_api {
		reverse_proxy php:8000
	}

	# Uploads : photos RDV (portail client) et logos atelier uniquement —
	# jamais les documents VO ni le reste de /uploads.
	@public_uploads {
		path /uploads/photos/* /uploads/logos/*
	}
	handle @public_uploads {
		reverse_proxy php:8000
	}

	# Mercure n'est pas exposé au public : aucune page publique ne s'y abonne
	# et le hub accepte les abonnements anonymes (fuite PII sinon).

	# Whitelisted public pages.
	@public_pages {
		path /landing /landing/* /public/booking* /public/suivi /public/suivi/* /public/demande /public/demande/* /public/mentions-legales* /public/politique-confidentialite* /restitution /restitution/*
	}
	handle @public_pages {
		reverse_proxy nuxt:3000
	}

	# Client portal (espace client) — served by client-nuxt on port 3001.
	handle /client {
		redir * /client/ 308
	}
	handle /client/* {
		reverse_proxy client-nuxt:3001
	}

	# Nuxt assets, branding, favicon — required by any page rendered above.
	@nuxt_assets {
		path /_nuxt/* /__nuxt/* /favicon.ico /branding/* /robots.txt /manifest.json /sw.js
	}
	handle @nuxt_assets {
		reverse_proxy nuxt:3000
	}

	# Root → redirect to public landing page.
	handle / {
		redir * /landing 302
	}

	# Everything else (admin, planning, vo, companion, login, profile, ...) is hidden.
	handle {
		respond "Not found" 404
	}
}
