<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 10px; color: #111827; margin: 16px 20px; }
        .cerfa-banner { border: 2px solid #111827; padding: 10px 12px; margin-bottom: 12px; }
        .header-table, .field-table, .check-table, .signature-table { width: 100%; border-collapse: collapse; }
        .header-table td { vertical-align: top; }
        .logo { max-width: 110px; max-height: 55px; margin-bottom: 6px; }
        .cerfa-code { font-size: 17px; font-weight: 700; text-align: right; }
        .cerfa-title { font-size: 16px; font-weight: 700; margin-top: 4px; text-transform: uppercase; }
        .cerfa-subtitle { font-size: 10px; color: #374151; }
        .intro { border: 1px solid #9ca3af; padding: 8px 10px; margin-bottom: 10px; background: #f9fafb; }
        .section { margin-bottom: 10px; }
        .section-title { background: #111827; color: #fff; padding: 5px 8px; font-weight: 700; font-size: 10px; text-transform: uppercase; }
        .field-table td { border: 1px solid #d1d5db; padding: 5px 6px; vertical-align: top; }
        .field-label { width: 24%; color: #374151; font-weight: 700; background: #f3f4f6; }
        .muted { color: #6b7280; }
        .check-table td { border: 1px solid #d1d5db; padding: 5px 6px; }
        .check { display: inline-block; width: 11px; height: 11px; border: 1px solid #111827; margin-right: 5px; text-align: center; font-size: 9px; line-height: 10px; }
        .warn { color: #b45309; font-weight: 700; }
        .ok { color: #166534; font-weight: 700; }
        .signature-table td { border: 1px solid #d1d5db; padding: 8px; height: 88px; vertical-align: top; }
        .footer { margin-top: 10px; font-size: 9px; color: #4b5563; border-top: 1px solid #d1d5db; padding-top: 6px; }
        ul { margin: 6px 0 0 16px; padding: 0; }
    </style>
</head>
<body>
    <div class="cerfa-banner">
        <table class="header-table">
            <tr>
                <td>
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo" class="logo">
                    {% endif %}
                    <div><strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong></div>
                    <div class="muted">
                        {% if atelier and atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                        {% if atelier and (atelier.cp or atelier.ville) %}{{ atelier.cp }} {{ atelier.ville }}<br>{% endif %}
                        {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    </div>
                </td>
                <td style="text-align:right; width: 42%;">
                    <div class="cerfa-code">CERFA 13751*02</div>
                    <div class="cerfa-title">Déclaration d'achat d'un véhicule d'occasion</div>
                    <div class="cerfa-subtitle">Rendu aligné sur le formulaire réglementaire SIV</div>
                    <div class="cerfa-subtitle">Dossier VO n° {{ purchase.id }} — édité le {{ 'now'|date('d/m/Y H:i') }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="intro">
        <strong>Usage dossier :</strong> ce rendu structure les données de la déclaration d'achat pour impression, contrôle interne et archivage. L'enregistrement SIV et le récépissé restent la preuve opposable de la déclaration.
        {% if blockers is empty %}
            <div class="ok" style="margin-top:6px;">Aucun blocage détecté avant saisie SIV.</div>
        {% else %}
            <div class="warn" style="margin-top:6px;">Points à régulariser avant enregistrement SIV :</div>
            <ul>
                {% for blocker in blockers %}
                    <li>{{ blocker }}</li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    <div class="section">
        <div class="section-title">1. Professionnel déclarant</div>
        <table class="field-table">
            <tr>
                <td class="field-label">Raison sociale</td>
                <td>{{ atelier and atelier.nom ? atelier.nom : 'À compléter' }}</td>
                <td class="field-label">SIRET</td>
                <td>{{ atelier and atelier.siret ? atelier.siret : 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Adresse</td>
                <td colspan="3">{% if atelier and atelier.adresse %}{{ atelier.adresse }}{% if atelier.cp or atelier.ville %}, {{ atelier.cp }} {{ atelier.ville }}{% endif %}{% else %}À compléter{% endif %}</td>
            </tr>
            <tr>
                <td class="field-label">Contact</td>
                <td>{{ atelier and atelier.telephone ? atelier.telephone : 'À compléter' }}</td>
                <td class="field-label">Référence dossier</td>
                <td>{{ purchase.sivReference ?? 'À renseigner après enregistrement' }}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">2. Ancien propriétaire / vendeur</div>
        <table class="field-table">
            <tr>
                <td class="field-label">Nom et prénom</td>
                <td>{{ purchase.seller.prenom ?? '' }} {{ purchase.seller.nom ?? '' }}</td>
                <td class="field-label">Téléphone</td>
                <td>{{ purchase.seller.telephone ?? 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Adresse</td>
                <td colspan="3">{{ purchase.seller.adresse ?? 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Email</td>
                <td>{{ purchase.seller.email ?? 'À compléter' }}</td>
                <td class="field-label">Pièce d'identité retranscrite</td>
                <td>{{ purchase.sellerIdType ?? 'À compléter' }}{% if purchase.sellerIdNumber %} — n° {{ purchase.sellerIdNumber }}{% endif %}{% if purchase.sellerIdDate %} — datée du {{ purchase.sellerIdDate|date('d/m/Y') }}{% endif %}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">3. Véhicule concerné</div>
        <table class="field-table">
            <tr>
                <td class="field-label">Immatriculation</td>
                <td>{{ purchase.vehicule.plaque ?? 'À compléter' }}</td>
                <td class="field-label">VIN</td>
                <td>{{ purchase.vehicule.vin ?? 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Marque / modèle</td>
                <td>{{ purchase.vehicule.marque ?? '—' }} {{ purchase.vehicule.modele ?? '' }}</td>
                <td class="field-label">Première MEC</td>
                <td>{% if purchase.vehicule.datePremiereMiseEnCirculation %}{{ purchase.vehicule.datePremiereMiseEnCirculation|date('d/m/Y') }}{% else %}À compléter{% endif %}</td>
            </tr>
            <tr>
                <td class="field-label">Type / variante / version</td>
                <td>{{ purchase.vehicule.typeVariante ?? 'À compléter' }}</td>
                <td class="field-label">Genre national</td>
                <td>{{ purchase.vehicule.genreNational ?? 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Dénomination commerciale</td>
                <td>{{ purchase.vehicule.denominationCommerciale ?? 'À compléter' }}</td>
                <td class="field-label">N° formule carte grise</td>
                <td>{{ purchase.vehicule.numeroFormuleCg ?? 'À compléter' }}</td>
            </tr>
            <tr>
                <td class="field-label">Kilométrage</td>
                <td>{{ purchase.vehicule.mileage ?? 'À compléter' }} km</td>
                <td class="field-label">Cylindrée</td>
                <td>{{ purchase.vehicule.cylindree ?? 'À compléter' }}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">4. Acquisition et pièces justificatives</div>
        <table class="field-table">
            <tr>
                <td class="field-label">Date d'achat</td>
                <td>{% if purchase.purchaseDate %}{{ purchase.purchaseDate|date('d/m/Y') }}{% else %}À compléter{% endif %}</td>
                <td class="field-label">Prix d'achat</td>
                <td>{{ purchase.purchasePrice|number_format(2, ',', ' ') }} €</td>
            </tr>
        </table>
        <table class="check-table" style="margin-top:6px;">
            <tr>
                <td><span class="check">{{ purchase.nonGageDate ? 'X' : '' }}</span> Certificat de situation administrative vérifié{% if purchase.nonGageDate %} le {{ purchase.nonGageDate|date('d/m/Y') }}{% endif %}</td>
                <td><span class="check">{{ purchase.controleTechniqueOk ? 'X' : '' }}</span> Contrôle technique traité selon l'âge du véhicule</td>
            </tr>
            <tr>
                <td><span class="check">X</span> Carte grise / cession / identité retranscrite dans le dossier</td>
                <td><span class="check">{{ purchase.sivReference ? 'X' : '' }}</span> Référence SIV renseignée{% if purchase.sivReference %} : {{ purchase.sivReference }}{% endif %}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">5. Déclaration du professionnel</div>
        <table class="signature-table">
            <tr>
                <td style="width:55%;">
                    Je soussigné, représentant du professionnel mentionné ci-dessus, certifie l'exactitude des informations retranscrites pour la déclaration d'achat du véhicule d'occasion désigné.
                </td>
                <td>
                    <strong>Date</strong><br>
                    {{ 'now'|date('d/m/Y') }}
                    <div style="margin-top:18px;"><strong>Cachet / signature</strong></div>
                </td>
            </tr>
        </table>
    </div>

    <div class="footer">
        Rendu aligné sur le CERFA 13751*02. À conserver dans le dossier avec le récépissé de déclaration d'achat SIV et les pièces réglementaires archivables.
    </div>
</body>
</html>
