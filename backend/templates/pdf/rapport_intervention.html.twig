<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 11px; color: #333; margin: 20px; }
        .header { display: flex; justify-content: space-between; border-bottom: 2px solid #2563eb; padding-bottom: 10px; margin-bottom: 15px; }
        .header h1 { color: #2563eb; font-size: 18px; margin: 0; }
        .info-block { margin-bottom: 12px; }
        .info-block h3 { color: #1e40af; font-size: 13px; border-bottom: 1px solid #ddd; padding-bottom: 3px; margin: 8px 0 5px; }
        table { width: 100%; border-collapse: collapse; margin: 5px 0; }
        table.info td { padding: 2px 8px; }
        table.info td:first-child { font-weight: bold; width: 35%; color: #555; }
        table.checks { border: 1px solid #ccc; }
        table.checks th { background: #f3f4f6; padding: 4px 6px; border: 1px solid #ccc; text-align: left; }
        table.checks td { padding: 4px 6px; border: 1px solid #ccc; }
        .status-ok { color: #16a34a; font-weight: bold; }
        .status-nok { color: #dc2626; font-weight: bold; }
        .section { margin-bottom: 12px; }
        .section-content { background: #f9fafb; padding: 6px 10px; border-radius: 4px; border: 1px solid #e5e7eb; }
        .signature-block { display: inline-block; width: 45%; border: 1px solid #ccc; padding: 8px; margin: 5px 2%; text-align: center; min-height: 80px; vertical-align: top; }
        .signature-block p { margin: 3px 0; font-size: 10px; color: #666; }
        .footer { margin-top: 20px; border-top: 1px solid #ddd; padding-top: 8px; font-size: 9px; color: #999; text-align: center; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: bold; }
        .badge-signe { background: #dcfce7; color: #166534; }
        .badge-brouillon { background: #fef9c3; color: #854d0e; }
    </style>
</head>
<body>
    <div class="header">
        <div>
            <h1>Rapport d'intervention</h1>
            <p>
                N° RDV : {{ rdv.id }}
                <span class="badge badge-{{ rapport.statut }}">{{ rapport.statut | upper }}</span>
            </p>
        </div>
        <div style="text-align: right; font-size: 10px; color: #666;">
            Édité le {{ "now" | date("d/m/Y H:i") }}
        </div>
    </div>

    {% if client %}
    <div class="info-block">
        <h3>Client</h3>
        <table class="info">
            <tr><td>Nom</td><td>{{ client.nom }} {{ client.prenom | default('') }}</td></tr>
            {% if client.telephone %}<tr><td>Téléphone</td><td>{{ client.telephone }}</td></tr>{% endif %}
            {% if client.email %}<tr><td>Email</td><td>{{ client.email }}</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    {% if vehicule %}
    <div class="info-block">
        <h3>Véhicule</h3>
        <table class="info">
            <tr><td>Marque / Modèle</td><td>{{ vehicule.marque | default('') }} {{ vehicule.modele | default('') }}</td></tr>
            {% if vehicule.immatriculation %}<tr><td>Immatriculation</td><td>{{ vehicule.immatriculation }}</td></tr>{% endif %}
            {% if rapport.kilometrageRestitution %}<tr><td>Kilométrage restitution</td><td>{{ rapport.kilometrageRestitution }} km</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    <div class="section">
        <h3>Travaux réalisés</h3>
        <div class="section-content">{{ rapport.travauxRealises | default('Non renseigné') | nl2br }}</div>
    </div>

    {% if rapport.alertes %}
    <div class="section">
        <h3>Alertes</h3>
        <div class="section-content">
            <ul>
            {% for alerte in rapport.alertes %}
                <li>{{ alerte }}</li>
            {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    <div class="section">
        <h3>Recommandations</h3>
        <div class="section-content">{{ rapport.recommandations | default('Aucune') | nl2br }}</div>
    </div>

    {% if rapport.prochaineRevisionKm or rapport.prochaineRevisionDate %}
    <div class="info-block">
        <h3>Prochaine révision</h3>
        <table class="info">
            {% if rapport.prochaineRevisionKm %}<tr><td>Kilométrage</td><td>{{ rapport.prochaineRevisionKm }} km</td></tr>{% endif %}
            {% if rapport.prochaineRevisionDate %}<tr><td>Date</td><td>{{ rapport.prochaineRevisionDate | date("d/m/Y") }}</td></tr>{% endif %}
        </table>
    </div>
    {% endif %}

    {% if rapport.garantie %}
    <div class="section">
        <h3>Garantie</h3>
        <div class="section-content">{{ rapport.garantie | nl2br }}</div>
    </div>
    {% endif %}

    {% if essai %}
    <div class="info-block">
        <h3>Essai routier</h3>
        <table class="info">
            {% if essai.kmDebut %}<tr><td>Km début</td><td>{{ essai.kmDebut }}</td></tr>{% endif %}
            {% if essai.kmFin %}<tr><td>Km fin</td><td>{{ essai.kmFin }}</td></tr>{% endif %}
            {% if essai.distance %}<tr><td>Distance</td><td>{{ essai.distance }} km</td></tr>{% endif %}
            {% if essai.dureeMinutes %}<tr><td>Durée</td><td>{{ essai.dureeMinutes }} min</td></tr>{% endif %}
        </table>

        {% if essai.pointsControle %}
        <table class="checks" style="margin-top: 8px;">
            <thead>
                <tr><th>Point de contrôle</th><th>Résultat</th><th>Commentaire</th></tr>
            </thead>
            <tbody>
            {% for pt in essai.pointsControle %}
                <tr>
                    <td>{{ pt.label }}</td>
                    <td>
                        {% if pt.ok is same as(true) %}<span class="status-ok">OK</span>
                        {% elseif pt.ok is same as(false) %}<span class="status-nok">NOK</span>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ pt.commentaire | default('') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}

        {% if essai.anomalies %}
        <p><strong>Anomalies :</strong> {{ essai.anomalies }}</p>
        {% endif %}
        {% if essai.actionsCorrectives %}
        <p><strong>Actions correctives :</strong> {{ essai.actionsCorrectives }}</p>
        {% endif %}
    </div>
    {% endif %}

    <div style="margin-top: 15px;">
        <h3>Signatures</h3>
        <div class="signature-block">
            <strong>Mécanicien</strong>
            {% if rapport.signatureMecanicien %}
                <p>Signé le {{ rapport.signeMecanicienAt | date("d/m/Y H:i") }}</p>
                <p style="font-style: italic;">✓ Signature enregistrée</p>
            {% else %}
                <p style="color: #999;">En attente</p>
            {% endif %}
        </div>
        <div class="signature-block">
            <strong>Client</strong>
            {% if rapport.signatureClient %}
                <p>Signé le {{ rapport.signeClientAt | date("d/m/Y H:i") }}</p>
                <p style="font-style: italic;">✓ Signature enregistrée</p>
            {% else %}
                <p style="color: #999;">En attente</p>
            {% endif %}
        </div>
    </div>

    <div class="footer">
        {% if rapport.signedHash %}
            Empreinte de vérification : {{ rapport.signedHash }}<br>
        {% endif %}
        Document généré automatiquement — Atelier MBZ
    </div>
</body>
</html>
