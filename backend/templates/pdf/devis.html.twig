<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #333; margin: 20px; }
        .header { border-bottom: 2px solid #f59e0b; padding-bottom: 10px; margin-bottom: 20px; }
        .header-table { width: 100%; border-collapse: collapse; }
        .header-left, .header-right { vertical-align: top; }
        .header-right { text-align: right; }
        .header h1 { color: #f59e0b; margin: 0; font-size: 18px; }
        .logo { max-width: 120px; max-height: 60px; margin-bottom: 8px; }
        .atelier-meta { font-size: 10px; color: #555; line-height: 1.4; }
        .info-grid { display: table; width: 100%; margin-bottom: 20px; }
        .info-col { display: table-cell; width: 50%; vertical-align: top; }
        .label { font-weight: bold; color: #666; }
        table.lines { width: 100%; border-collapse: collapse; margin-top: 10px; }
        table.lines th { background: #f59e0b; color: white; padding: 6px 8px; text-align: left; font-size: 10px; }
        table.lines td { padding: 5px 8px; border-bottom: 1px solid #ddd; }
        table.lines td.right { text-align: right; }
        .totals { float: right; width: 280px; margin-top: 20px; }
        .totals table { width: 100%; }
        .totals td { padding: 4px 6px; }
        .totals .total-ttc { font-weight: bold; font-size: 14px; border-top: 2px solid #333; }
        .validity { margin-top: 30px; background: #fffbeb; padding: 10px; border: 1px solid #f59e0b; }
    </style>
</head>
<body>
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="header-left">
                    {% if logo_data_uri %}
                    <img src="{{ logo_data_uri }}" alt="Logo atelier" class="logo">
                    {% endif %}
                    <div class="atelier-meta">
                        <strong>{{ atelier and atelier.nom ? atelier.nom : 'Atelier Moto' }}</strong><br>
                        {% if atelier and atelier.adresse %}{{ atelier.adresse }}<br>{% endif %}
                        {% if atelier and (atelier.cp or atelier.ville) %}{{ atelier.cp }} {{ atelier.ville }}<br>{% endif %}
                        {% if atelier and atelier.telephone %}Tél : {{ atelier.telephone }}<br>{% endif %}
                        {% if atelier and atelier.email %}{{ atelier.email }}<br>{% endif %}
                        {% if atelier and atelier.siret %}SIRET : {{ atelier.siret }}{% endif %}
                    </div>
                </td>
                <td class="header-right">
                    <h1>DEVIS</h1>
                    <p><strong>N° {{ devis.numeroDevis }}</strong> — {{ devis.dateCreation|date('d/m/Y') }}</p>
                </td>
            </tr>
        </table>
    </div>

    <div class="info-grid">
        <div class="info-col">
            <p class="label">Client</p>
            <p>{{ devis.snapClientPrenom ?? devis.client.prenom }} {{ devis.snapClientNom ?? devis.client.nom }}<br>
               {{ devis.snapClientTelephone ?? devis.client.telephone }}<br>
               {% if devis.snapClientEmail ?? devis.client.email %}{{ devis.snapClientEmail ?? devis.client.email }}{% endif %}</p>
        </div>
        <div class="info-col">
            <p class="label">Véhicule</p>
            {% set vMarque = devis.snapVehiculeMarque ?? (devis.vehicule ? devis.vehicule.marque : '') %}
            {% set vModele = devis.snapVehiculeModele ?? (devis.vehicule ? devis.vehicule.modele : '') %}
            {% set vPlaque = devis.snapVehiculePlaque ?? (devis.vehicule ? devis.vehicule.plaque : '') %}
            {% if vMarque or vModele %}
            <p>{{ vMarque }} {{ vModele }}<br>
               Plaque: {{ vPlaque }}<br>
               {% if devis.kilometrage %}Km: {{ devis.kilometrage }}{% endif %}</p>
            {% endif %}
        </div>
    </div>

    <table class="lines">
        <thead>
            <tr>
                <th>Désignation</th>
                <th>Type</th>
                <th>Qté</th>
                <th>P.U. HT</th>
                <th>TVA</th>
                <th>Total TTC</th>
            </tr>
        </thead>
        <tbody>
        {% for ligne in devis.lignes %}
            <tr>
                <td>{{ ligne.designation }}{% if ligne.descriptionDetail %}<br><small>{{ ligne.descriptionDetail }}</small>{% endif %}</td>
                <td>{{ ligne.typeLigne }}</td>
                <td class="right">{{ ligne.quantite }}</td>
                <td class="right">{{ ligne.prixUnitaireHt }} €</td>
                <td class="right">{{ ligne.tauxTva }}%</td>
                <td class="right">{{ ligne.totalLigneTtc }} €</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        <table>
            <tr><td>Total MO HT</td><td class="right">{{ devis.totalMoHt }} €</td></tr>
            <tr><td>Total Pièces HT</td><td class="right">{{ devis.totalPiecesHt }} €</td></tr>
            <tr><td><strong>Total HT</strong></td><td class="right"><strong>{{ devis.totalHt }} €</strong></td></tr>
            {% if devis.remiseMontant != '0.00' %}
            <tr><td>Remise ({{ devis.remisePourcentage }}%)</td><td class="right">-{{ devis.remiseMontant }} €</td></tr>
            {% endif %}
            <tr class="total-ttc"><td><strong>TOTAL TTC</strong></td><td class="right"><strong>{{ devis.totalTtc }} €</strong></td></tr>
            {% if devis.acompteDemande != '0.00' %}
            <tr><td>Acompte demandé</td><td class="right">{{ devis.acompteDemande }} €</td></tr>
            {% endif %}
        </table>
    </div>

    <div style="clear:both;"></div>

    <div class="validity">
        <p><strong>Validité du devis :</strong> jusqu'au {{ devis.dateValidite|date('d/m/Y') }}</p>
    </div>

    {% if devis.notesClient %}
    <p class="label" style="margin-top: 20px;">Notes</p>
    <p>{{ devis.notesClient|nl2br }}</p>
    {% endif %}

    <div style="margin-top: 40px;">
        <p><strong>Bon pour accord — Signature du client :</strong></p>
        <p style="height: 60px;">&nbsp;</p>
    </div>

    {# [SPRINT-5] I22 — Mention Art. R.112-1 Code consommation (devis obligatoire > 150 € HT) #}
    <div style="margin-top: 20px; font-size: 9px; color: #999; border-top: 1px solid #ddd; padding-top: 8px;">
        {% if devis.totalHt is defined and devis.totalHt > 150 %}
        <p>Devis établi conformément à l'article R.112-1 du Code de la consommation. Ce devis vous engage sans frais supplémentaires sauf accord écrit préalable.</p>
        {% endif %}
        <p>Devis valable {{ devis.joursValidite ?? 30 }} jours à compter de la date d'émission.</p>
    </div>
    {% include 'pdf/_paddock_footer.html.twig' %}
</body>
</html>
